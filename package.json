{
	"name": "bv-dns-security-mcp",
	"version": "1.0.0",
	"description": "Open-source MCP server for DNS and email security analysis — SPF, DMARC, DKIM, DNSSEC, SSL, MTA-STS, NS, CAA",
	"license": "MIT",
	"author": "BLACKVEIL Security",
	"homepage": "https://dns-mcp.blackveilsecurity.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/MadaBurns/bv-mcp.git"
	},
	"keywords": [
		"mcp",
		"dns",
		"security",
		"dmarc",
		"spf",
		"dkim",
		"dnssec",
		"cloudflare-workers",
		"model-context-protocol"
	],
	"private": true,
	"scripts": {
		"setup": "npm install && echo '✓ Dependencies installed. Run: npm run deploy'",
		"setup:kv": "wrangler kv namespace create RATE_LIMIT && wrangler kv namespace create SCAN_CACHE",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"deploy": "wrangler deploy",
		"test": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.17",
		"@cloudflare/workers-types": "^4.20260304.0",
		"@vitest/coverage-istanbul": "^3.2.4",
		"hono": "^4.12.2",
		"typescript": "^5.5.2",
		"vitest": "^3.2.4",
		"wrangler": "^4.68.1"
	},
	"dependencies": {
		"punycode": "^2.3.1"
	}
}
