{
	"name": "blackveil-dns",
	"version": "1.5.0",
	"description": "Open-source DNS & email security scanner — SPF, DMARC, DKIM, DNSSEC, SSL, and 15+ more checks via MCP. Detects spoofing risk, subdomain takeover, shadow domains, and typosquats. Scored and graded with remediation guidance.",
	"type": "module",
	"license": "BUSL-1.1",
	"author": "BLACKVEIL Security",
	"homepage": "https://blackveilsecurity.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MadaBurns/bv-mcp.git"
	},
	"keywords": [
		"blackveil",
		"dns",
		"security",
		"mcp",
		"email",
		"dmarc",
		"spf",
		"dkim",
		"dnssec",
		"cloudflare-workers",
		"model-context-protocol",
		"ai-tools",
		"email-spoofing",
		"phishing-prevention",
		"domain-security",
		"subdomain-takeover",
		"dns-audit",
		"email-authentication",
		"security-scanner",
		"mcp-server"
	],
	"bugs": {
		"url": "https://github.com/MadaBurns/bv-mcp/issues"
	},
	"engines": {
		"node": ">=18"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"blackveil-dns-mcp": "dist/stdio.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./stdio": {
			"types": "./dist/stdio.d.ts",
			"import": "./dist/stdio.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "wrangler dev",
		"deploy:private": "node scripts/deploy-private.mjs",
		"mcp:stdio": "node dist/stdio.js",
		"start": "wrangler dev",
		"prepack": "npm run build",
		"test": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"cf-typegen": "wrangler types",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.21",
		"@types/punycode": "^2.1.4",
		"@vitest/coverage-istanbul": "^3.2.4",
		"eslint": "^10.0.2",
		"hono": "^4.12.7",
		"tsup": "^8.5.0",
		"typescript": "^5.5.2",
		"typescript-eslint": "^8.56.1",
		"vitest": "^3.2.4",
		"wrangler": "^4.75.0"
	},
	"overrides": {
		"undici": "^7.24.0"
	},
	"dependencies": {
		"punycode": "^2.3.1"
	}
}
