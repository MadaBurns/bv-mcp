{
	"name": "blackveil-dns",
	"version": "2.21.3",
	"license": "BUSL-1.1",
	"type": "module",
	"bin": {
		"blackveil-dns-mcp": "dist/stdio.js"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MadaBurns/bv-mcp.git"
	},
	"mcpName": "com.blackveilsecurity/dns",
	"bugs": {
		"url": "https://github.com/MadaBurns/bv-mcp/issues"
	},
	"homepage": "https://github.com/MadaBurns/bv-mcp#readme",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "tsup",
		"build:wasm": "cd crates/bv-wasm-core && wasm-pack build --target web",
		"deploy:prod": "node scripts/inject-private-config.cjs && npx wrangler deploy --minify --config wrangler.production.jsonc",
		"test": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"validate:internal-deps": "node scripts/maintenance/validate-internal-deps.mjs",
		"generate-report": "bash scripts/generate-report.sh"
	},
	"dependencies": {
		"@blackveil/dns-checks": "^1.0.4",
		"@streamparser/json-whatwg": "^0.0.22",
		"drizzle-orm": "0.45.2",
		"marked": "^18.0.3",
		"punycode": "^2.3.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.4",
		"@cloudflare/workers-types": "4.20260511.1",
		"@types/marked": "^5.0.2",
		"@types/punycode": "^2.1.4",
		"drizzle-kit": "^0.31.10",
		"eslint": "9.39.3",
		"hono": "4.12.18",
		"playwright": "^1.60.0",
		"tsup": "8.5.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.59.3",
		"vitest": "4.1.6",
		"wrangler": "^4.90.0"
	},
	"overrides": {
		"@esbuild-kit/core-utils": {
			"esbuild": "0.25.12"
		}
	}
}
