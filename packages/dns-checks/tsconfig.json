{
	"compilerOptions": {
		/* tsup injects a deprecated `baseUrl` into its DTS build; TS 6.0 turns that into a hard error (TS5101). Silence until TS 7.0. */
		"ignoreDeprecations": "6.0",
		"target": "ES2024",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"outDir": "dist",
		"rootDir": "src",
		"lib": ["es2022", "dom"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/__tests__/**"]
}
