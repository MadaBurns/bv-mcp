{
  "name": "bv-dns-security-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": [
    "global_fetch_strictly_public"
  ],
  "observability": {
    "enabled": true
  },
  // Authentication secret for Bearer token auth on /mcp endpoint.
  // Set via `wrangler secret put SECRET` for production — do NOT commit real values.
  "vars": {
    "SECRET": "CHANGE-ME"
  }
}
