{
  "name": "bv-dns-security-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": [
    "global_fetch_strictly_public"
  ],
  "durable_objects": {
    "bindings": [
      { "name": "QUOTA_COORDINATOR", "class_name": "QuotaCoordinator" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["QuotaCoordinator"] }
  ],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    { "binding": "RATE_LIMIT", "id": "PLACEHOLDER_RATE_LIMIT_KV_ID" },
    { "binding": "SCAN_CACHE", "id": "PLACEHOLDER_SCAN_CACHE_KV_ID" },
    { "binding": "SESSION_STORE", "id": "PLACEHOLDER_SESSION_STORE_KV_ID" }
  ],
  // Optional auth: leave empty for open mode.
  "vars": {
    "BV_API_KEY": "",
    "PROVIDER_SIGNATURES_URL": ""
  }
}
