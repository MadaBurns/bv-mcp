{
  "name": "dns-security-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": [
    "global_fetch_strictly_public"
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "BV_API_KEY": ""
  }
  // No KV bindings by default. Runs standalone with `npx wrangler deploy`.
  // For production: create KV namespaces and add kv_namespaces binding.
  // For auth: set BV_API_KEY with `wrangler secret put BV_API_KEY`.
}
